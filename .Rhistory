# Load necessary packages
library(MASS)
# Simulate data
set.seed(123)
n <- 100
x <- rnorm(n, mean = 50, sd = 10)
y <- rpois(n, lambda = 2 + 0.1 * x)  # Poisson distributed response
data <- data.frame(x, y)
# Fit General Linear Model
glm_model <- glm(y ~ x, data = data, family = poisson(link = "log"))
# Summary of the GLM
summary(glm_model)
# Extract coefficients from the summary of GLM
coefficients <- coef(glm_model)
# Construct equation for y based on coefficients
intercept <- coefficients[1]
slope <- coefficients[2]
eqn <- paste0("y = e^(", round(intercept, 2), " + ", round(slope, 2), "x)")
# Print the equation
print(eqn)
# Load necessary packages
library(ggplot2)
# Create plot with data points
ggplot(data, aes(x = x, y = y)) +
geom_point() +
geom_smooth(method = "glm", method.args = list(family = "poisson"), se = FALSE) +
labs(x = "x", y = "y", title = "General Linear Model with Poisson Distribution") +
theme_minimal() #+
# Annotate plot with equation for y
#annotate("text", x = max(data$x), y = max(data$y), label = eqn, hjust = 1, vjust = 1, size = 4, parse = TRUE)
# Load necessary packages

library(tidyr)
library(ggplot2)
# Reshape data from wide to long format
df_long <- pivot_longer(df_,
cols = c("Hwk.1.1", "Hwk.1.2", "Hwk.1.3", "Hwk.2.1a", "Hwk.2.1b"),
names_to = "Homework",
values_to = "Scores")
# Define a function to categorize scores, handling NA values and non-numeric data
score_category <- function(score) {
if (is.na(score) || !is.numeric(score)) {
return("NA")
} else if (score < 0.6) {
return("Danger")
} else if (score < 0.9) {
return("Good")
} else {
return("SGold!")
}
}
# Apply the function to create a new column for color categorization
df_long$ScoreColor <- sapply(df_long$Scores, score_category)
# Create stacked histograms with conditional coloring
p <- ggplot(df_long, aes(x = Scores, fill = ScoreColor)) +
geom_histogram(binwidth = 0.1, color = "black") +
facet_grid(Homework ~ ., scales = "free_y") +
scale_fill_manual(values = c("Danger" = "red", "Good" = "green", "SGold!" = "gold", "NA" = "grey")) +
theme_minimal() +
labs(title = "Histograms of Homework Scores",
x = "Scores",
y = "Frequency") +
theme(text = element_text(size = 12))
p
ggsave("MAT211_HWK.png", plot = p, width = 10, height = 6)

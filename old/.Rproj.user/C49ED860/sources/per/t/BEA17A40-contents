## Definition

The `unit step function` is defined to be

$$u(t)= 0\qquad ,\quad t< 0 $$
$$\qquad=1\qquad ,\quad  t\geq 0$$
```{r,echo=FALSE}
b <- 3
a <- 0
h <- 1
plot(a,h,xlim = c(0,b),ylim = c(0,b),cex=2,pch = 16,col="blue", ylab="",xlab="",axes = FALSE,main=NULL)
par(mar=c(3,3,0,2)+0.1)
#text(-0.1,b,"u(t)")
mtext(side=2,at=2*h,text="u(t)",line=-1)
mtext(side=1,at=b*1.02,text="t",line=-3)#text(1.02*b,0,"t")
mtext(side=1,at=a,text=paste(a),line=-2)
#mtext(side=2,at=1,text="1")
arrows(-1,0,b,0, angle = 15, length = 0.1, lwd=3)
arrows(0,-1,0,b, angle = 15, length = 0.1, lwd=3)
segments(x0 = a, x1 = b, y0 = h, y1 = h,lwd = 2,lty=1, col = "blue") 
points(a,0, pch = 1, ylab="",xlab="", cex=1.9, bg="white", col="red",lwd=3, xaxt = "n", yaxt = "n")
```
:::


ggplot(data, aes(x = x, y = y)) +
geom_point() +
geom_smooth(method = "glm", method.args = list(family = "poisson"), se = FALSE) +
labs(x = "x", y = "y", title = "General Linear Model with Poisson Distribution") +
theme_minimal() #+
# Annotate plot with equation for y
annotate("text", x = max(data$x), y = max(data$y), label = eqn, hjust = 1, vjust = 1, size = 4, parse = TRUE)

df <- read.csv("Detailed_Homework_Results.csv")
df_ <- df[-c(1:4,36:42),]
names(df_)[1:4] <- c("Lastname", "Firstname","Email","Log-in")#,"Hwk.1.1"Hwk.1.2"  "Hwk.1.3"  "Hwk.2.1a" "Hwk.2.1b" "Hwk.2.4"  "Hwk.2.5"  "Hwk.3.1" "Hwk.3.2"  "X.5"

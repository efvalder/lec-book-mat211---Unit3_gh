# Required libraries
library(ggplot2)
library(rgl)
install.packages("rgl")
# Required libraries
library(ggplot2)
library(rgl)
# Simulate data
set.seed(123)
n <- 100
x1 <- rnorm(n, mean = 50, sd = 10)
x2 <- rnorm(n, mean = 30, sd = 5)
y <- 2 + 0.5 * x1 - 0.3 * x2 + rnorm(n, mean = 0, sd = 2)
data <- data.frame(x1, x2, y)
# Fit Multiple Linear Model
lm_model <- lm(y ~ x1 + x2, data = data)
# Plot in 3D
open3d()
plot3d(data$x1, data$x2, data$y, xlab = "x1", ylab = "x2", zlab = "y", col = "red", size = 1)
plane <- lm_model$coefficients[1] + lm_model$coefficients[2] * data$x1 + lm_model$coefficients[3] * data$x2
points3d(data$x1, data$x2, plane, col = "blue", size = 1)
rglwidget()
# Required libraries
library(ggplot2)
library(rgl)
# Simulate data
set.seed(123)
n <- 100
x1 <- rnorm(n, mean = 50, sd = 10)
x2 <- rnorm(n, mean = 30, sd = 5)
y <- 2 + 0.5 * x1 - 0.3 * x2 + rnorm(n, mean = 0, sd = 2)
data <- data.frame(x1, x2, y)
# Fit Multiple Linear Model
lm_model <- lm(y ~ x1 + x2, data = data)
# Plot in 3D
open3d()
plot3d(data$x1, data$x2, data$y, xlab = "x1", ylab = "x2", zlab = "y", col = "red", size = 1)
plane <- lm_model$coefficients[1] + lm_model$coefficients[2] * data$x1 + lm_model$coefficients[3] * data$x2
points3d(data$x1, data$x2, plane, col = "blue", size = 1)
rglwidget()

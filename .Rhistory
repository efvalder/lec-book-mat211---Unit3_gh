# Extract coefficients from the summary of lm
coefficients_lm <- coef(lm_model)
# Simulate data
set.seed(123)
n <- 100
x1 <- rnorm(n, mean = 50, sd = 10)
x2 <- rnorm(n, mean = 30, sd = 5)
y <- 2 + 0.5 * x1 - 0.3 * x2 + rnorm(n, mean = 0, sd = 2)
data <- data.frame(x1, x2, y)
# Fit Multiple Linear Model
lm_model <- lm(y ~ x1 + x2, data = data)
# Summary of the Multiple Linear Model
summary(lm_model)
# Extract coefficients from the summary of lm
coefficients_lm <- coef(lm_model)
intercept_lm <- coefficients_lm[1]
slope_x1 <- coefficients_lm[2]
slope_x2 <- coefficients_lm[3]
# Construct equation for y based on coefficients
eqn_lm <- substitute(paste("y =", intercept_lm, "+", slope_x1, "* x1 +", slope_x2, "* x2"))
# Create plot with data points and linear regression lines with confidence bands
ggplot(data, aes(x = x1, y = y)) +
geom_point() +
geom_smooth(method = "lm", formula = y ~ x1 + x2, se = TRUE) +
labs(x = "x1", y = "y", title = "Multiple Linear Regression Model") +
theme_minimal() +
# Annotate plot with equation for y
annotate("text", x = max(data$x1), y = max(data$y), label = as.character(eqn_lm), hjust = 1, vjust = 1, size = 4)
# Extract coefficients from the summary of lm
coefficients_lm <- coef(lm_model)
intercept_lm <- coefficients_lm[1]
slope_x1 <- coefficients_lm[2]
slope_x2 <- coefficients_lm[3]
# Construct equation for y based on coefficients
eqn_lm <- substitute(paste("y =", intercept_lm, "+", slope_x1, "* x1 +", slope_x2, "* x2"))
# Create plot with data points and linear regression lines with confidence bands
ggplot(data, aes(x = x1, y = y)) +
geom_point() +
geom_smooth(method = "lm", formula = y ~ x1 + x2, se = TRUE) +
labs(x = "x1", y = "y", title = "Multiple Linear Regression Model") +
theme_minimal()
